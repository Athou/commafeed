FROM ibm-semeru-runtimes:open-jdk-25.0.3.0-jre@sha256:9ff5b13fa9a8e053b63d138017c369c0d234036d4664c80444145766f17d9af6
EXPOSE 8082

RUN mkdir -p /commafeed/data
VOLUME /commafeed/data

COPY artifacts/extracted-jvm-package/quarkus-app/ /commafeed
WORKDIR /commafeed

CMD ["java", \
    "-Xtune:virtualized", \
    "-Xminf0.05", \
    "-Xmaxf0.1", \
    "-jar", \
    "quarkus-run.jar"]
