FROM ibm-semeru-runtimes:open-jdk-25.0.3.0-jre@sha256:16dc91c9bcf5fd2d9844fd267252bb59b4ed9d9ba586531231527cc348d4afd7
EXPOSE 8082

RUN mkdir -p /commafeed/data
VOLUME /commafeed/data

COPY artifacts/extracted-jvm-package/quarkus-app/ /commafeed
WORKDIR /commafeed

CMD ["java", \
    "-Xtune:virtualized", \
    "-Xminf0.05", \
    "-Xmaxf0.1", \
    "-jar", \
    "quarkus-run.jar"]
